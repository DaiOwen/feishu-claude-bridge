# Feishu App Credentials
# Get these from: https://open.feishu.cn -> Your App -> Credentials & Basic Info
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_secret_here

# Encrypt Key (leave empty if not configured in Feishu app)
FEISHU_ENCRYPT_KEY=

# Verification Token (leave empty if not configured)
FEISHU_VERIFICATION_TOKEN=

# Working directory for Claude Code (defaults to user home)
# CLAUDE_WORK_DIR=C:\Users\YourName
